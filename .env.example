# Server
PURCHASE_AUTO_HOST=127.0.0.1
PURCHASE_AUTO_PORT=5008
PURCHASE_AUTO_DB_PATH=data/purchase_auto.sqlite3
PURCHASE_AUTO_ARTIFACT_DIR=artifacts

# Safety switch: keep enabled until live browser automation is tuned on the 담당자 PC.
PURCHASE_AUTO_DRY_RUN=1
PURCHASE_AUTO_HEADLESS=0

# Live automation gates
PURCHASE_AUTO_ENABLE_LIVE_COMPUZONE_ORDER=0
PURCHASE_AUTO_ENABLE_LIVE_GROUPWARE_SUBMIT=0

# Browser profiles. Use persistent profiles so 담당자 PC login sessions can be reused.
PURCHASE_AUTO_COMPUZONE_PROFILE_DIR=.profiles/compuzone
PURCHASE_AUTO_GROUPWARE_PROFILE_DIR=.profiles/groupware
PURCHASE_AUTO_COMPUZONE_CDP_URL=
PURCHASE_AUTO_GROUPWARE_CDP_URL=
# Keep this 0 unless you intentionally want Purchase_Auto to attach to an already-open Chrome debugging session.
PURCHASE_AUTO_ALLOW_EXISTING_BROWSER_CDP=0

# Compuzone
PURCHASE_AUTO_COMPUZONE_ID=
PURCHASE_AUTO_COMPUZONE_PASSWORD=
PURCHASE_AUTO_COMPUZONE_CLEAR_CART_BEFORE_ORDER=1
PURCHASE_AUTO_COMPUZONE_CART_URL=https://www.compuzone.co.kr/bsk/basket_main.htm
PURCHASE_AUTO_COMPUZONE_QUOTE_URL_TEMPLATE=https://www.compuzone.co.kr/form/form_assemble.htm?wd=&tb=iorder&from_where=internet_manager&order_state_no={order_no}&settle=settle
PURCHASE_AUTO_COMPUZONE_DEPOSITOR_NAME=
PURCHASE_AUTO_COMPUZONE_DELIVERY_NAME=평택 전산팀
PURCHASE_AUTO_COMPUZONE_DELIVERY_KEYWORDS=평택 전산팀,수월암4길 200,010-2227-0009
PURCHASE_AUTO_COMPUZONE_BUSINESS_NUMBER=125-81-05619
PURCHASE_AUTO_COMPUZONE_BUSINESS_CONTACT_NAME=윤기옥

# Daou groupware
PURCHASE_AUTO_GROUPWARE_BASE_URL=https://gw.dae-seung.co.kr
PURCHASE_AUTO_GROUPWARE_FORM_URL_DAESEUNG=https://gw.dae-seung.co.kr/app/approval/document/new/223/5646
PURCHASE_AUTO_GROUPWARE_FORM_URL_DAESEUNG_PRECISION=https://gw.dae-seung.co.kr/app/approval/document/new/223/5536
PURCHASE_AUTO_GROUPWARE_FORM_URL_ILGANG=
