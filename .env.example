# Server
PURCHASE_AUTO_HOST=127.0.0.1
PURCHASE_AUTO_PORT=5008
PURCHASE_AUTO_DB_PATH=data/purchase_auto.sqlite3
PURCHASE_AUTO_ARTIFACT_DIR=artifacts

# Safety switch: keep enabled until live browser automation is tuned on the 담당자 PC.
PURCHASE_AUTO_DRY_RUN=1
PURCHASE_AUTO_HEADLESS=0

# Live automation gates
PURCHASE_AUTO_ENABLE_LIVE_COMPUZONE_ORDER=0
PURCHASE_AUTO_ENABLE_LIVE_GROUPWARE_SUBMIT=0

# Browser profiles. Use persistent profiles so 담당자 PC login sessions can be reused.
PURCHASE_AUTO_COMPUZONE_PROFILE_DIR=.profiles/compuzone
PURCHASE_AUTO_GROUPWARE_PROFILE_DIR=.profiles/groupware

# Compuzone
PURCHASE_AUTO_COMPUZONE_CART_URL=https://www.compuzone.co.kr/mypage/cart.htm
PURCHASE_AUTO_COMPUZONE_QUOTE_URL_TEMPLATE=https://www.compuzone.co.kr/order/order_quote_pdf.htm?OrderNo={order_no}
PURCHASE_AUTO_COMPUZONE_DEPOSITOR_NAME=

# Daou groupware
PURCHASE_AUTO_GROUPWARE_BASE_URL=https://gw.dae-seung.co.kr
PURCHASE_AUTO_GROUPWARE_FORM_URL_DAESEUNG=https://gw.dae-seung.co.kr/app/approval/document/new/223/5646
PURCHASE_AUTO_GROUPWARE_FORM_URL_DAESEUNG_PRECISION=
PURCHASE_AUTO_GROUPWARE_FORM_URL_ILGANG=
